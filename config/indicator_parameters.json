{
  "strategy_name": "融合策略 v1.0",
  "description": "融合 MACD/RSI/KDJ/BOLL 多时间框架评分与趋势/背离/K线形态分析，并集成 Transformer 模型预测的综合策略",
  "trend_following_strategy_name": "趋势跟踪v1.0",
  "trend_reversal_strategy_name": "趋势反转v1.0",
  "t_plus_0_strategy_name": "T+0(VWAP)v1.0",

  "base_scoring": {
    "timeframes": ["5", "15", "30", "60", "D"],
    "score_indicators": ["macd", "rsi", "kdj", "boll", "cci", "mfi", "roc", "dmi", "sar"],
    "rsi_period": 9,
    "rsi_oversold": 30,
    "rsi_overbought": 70,
    "rsi_extreme_oversold": 25,
    "rsi_extreme_overbought": 75,
    "kdj_period_k": 7,
    "kdj_period_d": 3,
    "kdj_period_j": 3,
    "kdj_oversold": 25,
    "kdj_overbought": 75,
    "boll_period": 15,
    "boll_std_dev": 2.2,
    "macd_fast": 8,
    "macd_slow": 26,
    "macd_signal": 7,
    "cci_period": 14,
    "cci_threshold": 100,
    "cci_extreme_threshold": 200,
    "mfi_period": 14,
    "mfi_oversold": 20,
    "mfi_overbought": 80,
    "mfi_extreme_oversold": 10,
    "mfi_extreme_overbought": 90,
    "roc_period": 12,
    "dmi_period": 14,
    "adx_threshold": 20,
    "adx_strong_threshold": 30,
    "sar_step": 0.02,
    "sar_max": 0.2,
    "weights": {
      "5": 0.15,
      "15": 0.45,
      "30": 0.25,
      "60": 0.15,
      "D": 0.0
    }
  },

  "volume_confirmation": {
    "enabled": true,
    "tf": "15",
    "amount_ma_period": 15,
    "cmf_period": 20,
    "obv_ma_period": 10,
    "boost_factor": 1.3,
    "penalty_factor": 0.7
  },

  "divergence_detection": {
    "enabled": true,
    "check_regular_bullish": true,
    "check_hidden_bullish": true,
    "check_hidden_bearish": true,
    "tf": "15",
    "price_period": 5,
    "lookback": 10,
    "indicators": {
      "macd_hist": true,
      "rsi": true,
      "mfi": true,
      "obv": false
    },
    "thresholds": {
        "cmf": -0.05,
        "mfi": 40
    },
    "divergence_penalty_factor": 0.45
  },

  "kline_pattern_detection": {
    "enabled": true,
    "tf": ["5", "15", "30", "60", "D"]
  },

  "trend_analysis": {
    "ema_periods": [5, 13, 21, 55, 233],
    "long_term_ema_period": 233,
    "volatility_window": 8
  },

  "t_plus_0_signals": {
    "enabled": true,
    "focus_timeframe": "5",
    "buy_dev_threshold": -0.004,
    "sell_dev_threshold": 0.004,
    "use_long_term_filter": false
  },

  "feature_engineering_params": {
    "apply_on_timeframes": ["5", "15", "30", "60", "D"],
    "calculate_atr": true,
    "atr_params": {"period": 14},
    "calculate_hv": true,
    "hv_params": {"period": 20},
    "calculate_kc": true,
    "kc_params": {"ema_period": 20, "atr_period": 10},
    "calculate_mom": true,
    "mom_params": {"period": 10},
    "calculate_willr": true,
    "willr_params": {"period": 14},
    "calculate_vroc": true,
    "vroc_params": {"period": 10},
    "calculate_aroc": true,
    "aroc_params": {"period": 10},
    "ema_periods": [5, 10, 20, 60],
    "sma_periods": [5, 10, 20, 60],
    "ema_periods_for_relation": [5, 20, 60],
    "sma_periods_for_relation": [5, 20, 60],
    "indicators_for_difference": [
        {"base_name": "RSI", "params_key": ["rsi_period"], "default_period": [14]},
        {"base_name": "MACD", "params_key": ["macd_fast", "macd_slow", "macd_signal"], "default_period": [12, 26, 9]},
        {"base_name": "K", "params_key": ["kdj_period_k", "kdj_period_d", "kdj_period_j"], "default_period": [9, 3, 3]},
        {"base_name": "D", "params_key": ["kdj_period_k", "kdj_period_d", "kdj_period_j"], "default_period": [9, 3, 3]},
        {"base_name": "J", "params_key": ["kdj_period_k", "kdj_period_d", "kdj_period_j"], "default_period": [9, 3, 3]},
        {"base_name": "ADX", "params_key": ["dmi_period"], "default_period": [14]}
    ],
    "difference_periods": [1, 5],
    "calculate_vwap": true
  },

  "trend_following_params": {
    "focus_timeframe": "30",
    "trend_confirmation_periods": 3,
    "focus_weight": 0.45,
    "timeframe_weights": {
        "5": 0.1,
        "15": 0.3,
        "30": 0.4,
        "60": 0.15,
        "D": 0.05
    },
    "trend_indicators": ["dmi", "sar", "macd", "ema_alignment", "obv", "rsi"],
    "rule_signal_weights": {
        "base_score": 0.4,
        "alignment": 0.2,
        "long_context": 0.1,
        "momentum": 0.1,
        "ema_cross": 0.05,
        "boll_breakout": 0.05,
        "adx_strength": 0.05,
        "vwap_deviation": 0.025,
        "volume_spike": 0.025
    },
    "volume_boost_factor": 1.3,
    "volume_penalty_factor": 0.7,
    "volume_spike_threshold": 2.0,
    "volatility_threshold_high": 10,
    "volatility_threshold_low": 5,
    "adx_adjustment_factor": 15.0,
    "adx_strong_threshold": 30,
    "adx_moderate_threshold": 20,
    "trend_duration_threshold_strong": 5,
    "trend_duration_threshold_moderate": 10,
    "stoch_oversold_threshold": 20,
    "stoch_overbought_threshold": 80,
    "vwap_deviation_threshold": 0.01,
    "volatility_benchmark": 5.0,
    "transformer_window_size": 60,
    "transformer_target_column": "final_rule_signal",
    "transformer_plot_history": true,
    "transformer_data_prep_config": {
        "scaler_type": "standard",
        "train_split": 0.7,
        "val_split": 0.15,
        "apply_variance_threshold": false,
        "variance_threshold_value": 0.01,
        "use_pca": false,
        "pca_n_components": 0.99,
        "pca_solver": "auto",
        "use_feature_selection": true,
        "feature_selector_model_type": "rf",
        "fs_model_n_estimators": 200,
        "fs_model_max_depth": 10,
        "fs_max_features": 80,
        "fs_selection_threshold": "median",
        "target_scaler_type": "minmax"
    },
    "transformer_model_config": {
      "d_model": 128,
      "nhead": 8,
      "dim_feedforward": 512,
      "nlayers": 4,
      "dropout": 0.1,
      "activation": "gelu"
    },
    "transformer_training_config": {
      "epochs": 200,
      "batch_size": 64,
      "learning_rate": 0.0005,
      "weight_decay": 0.001,
      "optimizer": "adamw",
      "loss": "mse",
      "early_stopping_patience": 40,
      "reduce_lr_patience": 15,
      "reduce_lr_factor": 0.5,
      "monitor_metric": "val_mae",
      "verbose": 1,
      "tensorboard_log_dir": "logs/tensorboard",
      "clip_grad_norm": 1.0
    },
     "signal_combination_weights": {
        "rule_weight": 0.6,
        "lstm_weight": 0.4
    }
  },

  "trend_reversal_params": {
      "focus_timeframe": "30",
      "focus_weight": 0.5,
      "reversal_indicators": ["rsi", "kdj", "cci", "boll", "divergence", "kline", "willr", "atr", "hv"],
      "long_term_trend_filter": {
          "enabled": true,
          "timeframe": "D",
