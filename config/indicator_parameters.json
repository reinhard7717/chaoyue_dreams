          "kline_continuation": -0.05,
          "kline_marubozu": -0.1,
          "kline_doji": 0.0,
          "volume_spike": 0.08,
          "willr_reversal": 0.1,
          "atr_volatility": 0.07,
          "hv_environment": 0.05,
          "max_abs_signal": 1.0
